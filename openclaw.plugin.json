{
  "id": "octer-channel",
  "name": "Octer Channel",
  "description": "WebSocket bridge to Octer.ai cloud backend",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Octer.ai API key (starts with evo_)"
      },
      "name": {
        "type": "string",
        "description": "Display name for this account"
      }
    },
    "required": []
  },
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "help": "Your Octer.ai API key (starts with evo_)",
      "sensitive": true,
      "placeholder": "evo_..."
    }
  }
}
